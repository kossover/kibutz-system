rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Recipes - Public Access
    match /recipes/{document=**} {
      allow read, write: if true;
    }
    
    // Landing Pages - Public Read (for redirects)
    match /landingPages/{page} {
      allow read: if true;
      allow write: if request.auth != null; // Admin only
    }

    // Events - Public Read
    // Events - Public Read
    match /events/{event} {
      allow read: if true;
      allow create, delete: if request.auth != null; // Admin only
      // Allow update if authenticated OR if only updating participants counts (for guest registration)
      allow update: if request.auth != null || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentParticipants', 'stats']));
    }

    // Users - Public Create (Guests), Public Read (Phone Lookup)
    match /users/{user} {
      allow read: if true; // Allows phone lookup
      allow create: if true; // allow guest creation (or restrict to role == 'guest')
      allow update, delete: if request.auth != null;
    }

    // Event Registrations - Public Access (Guests need write access)
    match /eventRegistrations/{reg} {
      allow read, write: if true;
    }

    // Map Points & Categories - Public Read
    match /mapPoints/{point} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /mapCategories/{category} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mishloach Manot - Public Read & Write for Registration
    match /mishloachManot/{doc} {
      allow read, write: if true;
    }
    
    // Settings - Public Read (needed for registration page)
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Documents for Signature - Public Read and Update (auth is handled via phone validation in code)
    match /documents_for_signature/{document} {
      allow read, update: if true;
      allow create, delete: if request.auth != null;
    }

    // Professionals - Public Read
    match /professionals/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /professionalCategories/{category} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Library Shifts - Public Read and Write
    match /libraryShifts/{shift} {
      allow read, write: if true;
    }

    // Default rule: only authenticated users can access other data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
